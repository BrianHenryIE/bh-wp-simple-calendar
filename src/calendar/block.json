{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "simple-calendar/calendar",
	"version": "1.0.0",
	"title": "Simple Calendar",
	"category": "widgets",
	"icon": "calendar-alt",
	"description": "Display upcoming events from one or more iCal calendar feeds.",
	"keywords": [ "calendar", "ical", "events", "schedule" ],
	"textdomain": "bh-wp-simple-calendar",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"text": true,
			"background": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"calendarUrls": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string"
			}
		},
		"eventCount": {
			"type": "number",
			"default": 10
		},
		"eventPeriod": {
			"type": "number",
			"default": 92
		}
	},
	"providesContext": {
		"simple-calendar/events": "events"
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
