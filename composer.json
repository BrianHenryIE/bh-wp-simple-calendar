{
	"name": "brianhenryie/bh-wp-simple-calendar",
	"description": "This is a short description of what plugin_title does.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0+-or-later",
	"authors": [
		{
			"name": "Matthew Pemrich"
		},
		{
			"name": "Nico Boehr"
		},
		{
			"name": "Bram Waasdorp",
			"email": "bram@waasdorpsoekhan.nl"
		},
		{
			"name": "Brian Henry",
			"email": "BrianHenryIE@gmail.com"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"platform": {
			"php": "8.4"
		},
		"process-timeout": 0,
		"sort-packages": true,
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true,
			"johnpbloch/wordpress-core-installer": true
		}
	},
	"repositories": {
		"composer/composer": {
			"type": "composer",
			"url": "https://wpackagist.org"
		},
		"wordpress/wordpress": {
			"url": "https://github.com/WordPress/wordpress-develop",
			"type": "git"
		}
	},
	"require": {
		"johngrogg/ics-parser": "^3",
		"alleyinteractive/wordpress-autoloader": "*",
		"brianhenryie/bh-wp-private-uploads": "^0.2",
		"brianhenryie/bh-wp-logger": "^0.2",
		"lucatume/di52": "^4"
	},
	"require-dev": {
		"10up/wp_mock": "^1.0",
		"antecedent/patchwork": "^2.1",
		"brianhenryie/color-logger": "*",
		"brianhenryie/strauss": "*",
		"dealerdirect/phpcodesniffer-composer-installer": "*",
		"johnpbloch/wordpress": "*",
		"lucatume/wp-browser": "^4",
		"phpcompatibility/phpcompatibility-wp": "*",
		"phpstan/extension-installer": "*",
		"phpunit/phpcov": "*",
		"squizlabs/php_codesniffer": "*",
		"szepeviktor/phpstan-wordpress": "*",
		"wordpress/wordpress": "*",
		"wp-cli/dist-archive-command": "dev-main",
		"wp-cli/wp-cli-bundle": "^2.12",
		"wp-cli/wp-cli-tests": "*",
		"wp-coding-standards/wpcs": "*",
		"wpackagist-theme/twentytwenty": "*"
	},
	"extra": {
		"strauss": {
			"namespace_prefix": "BrianHenryIE\\WP_Simple_Calendar\\",
			"target_directory": "/vendor-prefixed/",
			"classmap_prefix": "BH_WP_Simple_Calendar_",
			"namespace_replacement_patterns": {
				"~BrianHenryIE\\\\(.*)~": "BrianHenryIE\\WP_Simple_Calendar\\\\$1"
			},
			"override_autoload": {
				"johngrogg/ics-parser": {
					"classmap": ["src"]
				}
			}
		}
	},
	"scripts": {
		"post-install-cmd": [
			"strauss",
			"@sync-composer-wpenv"
		],
		"post-update-cmd": [
			"strauss",
			"@sync-composer-wpenv"
		],
		"test": [
			"codecept run unit",
			"codecept run wpunit",
			"codecept run integration"
		],
		"test-coverage": [
			"codecept run unit --coverage unit.cov &",
			"codecept run wpunit --coverage wpunit.cov &",
			"phpcov merge --clover tests/_output/clover.xml --html tests/_output/html tests/_output;",
			"open tests/_output/html/index.html"
		],
		"cs-fix": [
			"phpcbf || true",
			"phpcs || true",
			"phpstan analyse --memory-limit 1G"
		],
		"cs-fix-changes": [
			"updated_files=$( git status | grep 'modified:\\s.*.php$' | cut -c14- | awk '{ printf(\"%s \", $0) }' ); phpcbf $(echo $updated_files); phpcs $(echo $updated_files); phpstan analyse $(echo $updated_files) --memory-limit 1G"
		],
		"php-compatibility": [
			"phpcs -p src templates vendor-prefixed --standard=PHPCompatibilityWP --runtime-set testVersion 7.4-"
		],
		"create-plugin-archive": [
			"wp i18n make-pot src languages/$(basename \"$PWD\").pot --domain=$(basename \"$PWD\")",
			"wp dist-archive . ./dist-archive --plugin-dirname=$(basename \"$PWD\") --create-target-dir"
		],
		"github-actions": [
			"act -P ubuntu-latest=shivammathur/node:latest"
		],
		"sync-composer-wpenv": [
			"for name in $(cat .wp-env.json | jq '.mappings | values[]' | sed -r 's/^\\\"|\\\"$//g'); do [ ! -d $name ] && [ ! -f $name ] && echo $name && jq 'del(.. | select(. ==\"'$name'\"))' .wp-env.json | sponge .wp-env.json || true; done",
			"find wp-content/plugins -type d -depth 1 ! -type l | sort -h | jq -Rn '[inputs]' | jq 'reduce .[] as $item ({}; . + {$item:$item})' | jq '.[] |= \"./\\(.)\"' | jq '. | {mappings: .}' | jq --sort-keys -s '.[] * $existing[]' --slurpfile existing .wp-env.json | sponge .wp-env.json"
		]
	}
}
