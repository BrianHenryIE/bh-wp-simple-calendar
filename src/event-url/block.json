{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "simple-calendar/event-url",
	"version": "1.0.0",
	"title": "Event URL",
	"category": "widgets",
	"icon": "admin-links",
	"description": "Displays a link to the event URL.",
	"keywords": [ "event", "url", "link" ],
	"textdomain": "bh-wp-simple-calendar",
	"parent": [ "simple-calendar/event-template" ],
	"supports": {
		"html": false,
		"color": { "text": true, "background": true },
		"spacing": { "margin": true, "padding": true },
		"typography": { "fontSize": true, "fontFamily": true }
	},
	"attributes": {
		"linkText": {
			"type": "string",
			"default": ""
		}
	},
	"usesContext": [
		"simple-calendar/eventUrl"
	],
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
